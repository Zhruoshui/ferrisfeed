FROM ubuntu:24.04 AS builder

ENV DEBIAN_FRONTEND=noninteractive
ARG FLUTTER_REVISION=924134a44c189315be2148659913dda1671cbe99
ARG FRB_REVISION=254b193e3fa9b223865cc9ff046a4b52135ccedf

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    build-essential \
    ca-certificates \
    curl \
    git \
    libssl-dev \
    pkg-config \
    unzip \
    xz-utils \
    zip \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL https://sh.rustup.rs | sh -s -- -y --profile minimal
ENV PATH="/root/.cargo/bin:/root/.pub-cache/bin:/opt/flutter/bin:${PATH}"
ENV CARGO_NET_GIT_FETCH_WITH_CLI=true

RUN git clone --filter=blob:none https://github.com/flutter/flutter.git /opt/flutter \
    && git -C /opt/flutter checkout "${FLUTTER_REVISION}"
RUN git clone --filter=blob:none https://github.com/fzyzcjy/flutter_rust_bridge.git /opt/flutter_rust_bridge \
    && git -C /opt/flutter_rust_bridge checkout "${FRB_REVISION}" \
    && git config --global url."file:///opt/flutter_rust_bridge".insteadOf "https://github.com/fzyzcjy/flutter_rust_bridge" \
    && git config --global url."file:///opt/flutter_rust_bridge".insteadOf "https://github.com/fzyzcjy/flutter_rust_bridge.git"
RUN flutter config --enable-web
RUN flutter precache --web
RUN flutter --version
RUN rustup component add rustfmt \
    && rustup target add wasm32-unknown-unknown \
    && rustup toolchain install nightly --profile minimal \
    && rustup component add rust-src --toolchain nightly \
    && rustup target add wasm32-unknown-unknown --toolchain nightly
RUN cargo install --path /opt/flutter_rust_bridge/frb_codegen
RUN cargo install wasm-pack --locked --version 0.15.0

WORKDIR /app
COPY . .
RUN flutter pub get
RUN ./tools/rebuild-web
RUN flutter build web

FROM nginx:1.27-alpine

COPY nginx/web.conf /etc/nginx/conf.d/default.conf
COPY --from=builder /app/build/web /usr/share/nginx/html

EXPOSE 80
