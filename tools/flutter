#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
fvm_flutter="$repo_root/.fvm/flutter_sdk/bin/flutter"

if [[ -x "$fvm_flutter" ]]; then
  exec "$fvm_flutter" "$@"
fi

if command -v flutter >/dev/null 2>&1; then
  exec flutter "$@"
fi

echo "Flutter SDK not found. Run 'fvm use' or install Flutter on PATH." >&2
exit 127
