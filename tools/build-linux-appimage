#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

dist_dir="${DIST_DIR:-dist}"
appimage_name="${APPIMAGE_NAME:-RSS_Reader-x86_64.AppImage}"
appdir="$repo_root/build/appimage/RSSReader.AppDir"
bundle_dir="$repo_root/build/linux/x64/release/bundle"
icon_source="$repo_root/web/icons/Icon-512.png"
appimagetool="${APPIMAGETOOL:-}"

if [[ -z "$appimagetool" ]]; then
  if command -v appimagetool >/dev/null 2>&1; then
    appimagetool="$(command -v appimagetool)"
  else
    echo "appimagetool not found." >&2
    echo "Install it or run with APPIMAGETOOL=/path/to/appimagetool." >&2
    exit 1
  fi
fi

if [[ ! -x "$appimagetool" ]]; then
  echo "appimagetool is not executable: $appimagetool" >&2
  exit 1
fi

"$repo_root/tools/build-linux-bundle" "$@"

if [[ ! -d "$bundle_dir" ]]; then
  echo "Expected Linux bundle directory not found: $bundle_dir" >&2
  exit 1
fi

if [[ ! -f "$icon_source" ]]; then
  echo "Expected AppImage icon not found: $icon_source" >&2
  exit 1
fi

rm -rf "$appdir"
mkdir -p "$appdir/usr/share/icons/hicolor/512x512/apps" "$repo_root/$dist_dir"
cp -a "$bundle_dir/." "$appdir/"
cp "$icon_source" "$appdir/rss_reader.png"
cp "$icon_source" "$appdir/usr/share/icons/hicolor/512x512/apps/rss_reader.png"

cat > "$appdir/AppRun" <<'EOF'
#!/usr/bin/env bash
set -euo pipefail

app_dir="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
exec "$app_dir/rss_reader" "$@"
EOF
chmod +x "$appdir/AppRun"

cat > "$appdir/rss_reader.desktop" <<'EOF'
[Desktop Entry]
Type=Application
Name=RSS Reader
Comment=Flutter and Rust RSS reader
Exec=rss_reader
Icon=rss_reader
Categories=Network;News;
Terminal=false
EOF

appimage_path="$repo_root/$dist_dir/$appimage_name"
rm -f "$appimage_path"

ARCH=x86_64 APPIMAGE_EXTRACT_AND_RUN=1 "$appimagetool" --no-appstream "$appdir" "$appimage_path"

echo
echo "Linux AppImage:"
echo "$appimage_path"
